# AUDITCARGO — Variáveis de ambiente
PORT=3000
NODE_ENV=development

# CORS (opcional, para produção)
# FRONTEND_URL=https://seu-frontend.vercel.app

# Turso (banco em nuvem — opcional, fallback para SQLite local)
# TURSO_URL=libsql://seu-banco.turso.io
# TURSO_AUTH_TOKEN=seu_token_aqui

# Anthropic (obrigatório para upload de boleto com IA)
# ANTHROPIC_API_KEY=sua_chave_aqui

# Melhor Envio (opcional — habilita cotação real de frete)
# MELHOR_ENVIO_TOKEN=seu_token_aqui
# MELHOR_ENVIO_BASE_URL=https://www.melhorenvio.com.br
# Sem token: Reference Engine usa automaticamente o motor estimativo (fallback)
# Sandbox: MELHOR_ENVIO_BASE_URL=https://sandbox.melhorenvio.com.br
